name = "Signaculum"
version = "0.1.0"
description = "Lean 4 製 SHIORI/3.0 栞(Ukagaka ghost)ビブリオテーカ(bibliotheca)"
keywords = ["ukagaka", "shiori", "ghost", "sakura-script"]

[leanOptions]
autoImplicit = false
pp.unicode.fun = true

[[require]]
name = "batteries"
scope = "leanprover-community"
rev = "main"

[[require]]
name = "Repl"
git = "https://github.com/leanprover-community/repl"
[[require]]
name = "LemmaGeneralis"
git = "https://github.com/rejafdofs/LemmaGeneralis"
rev = "main"

# ディレクトゥム SSTP — WM_COPYDATA ヴィアー SSP ニ ソウシン スルニャン
[[extern_lib]]
name = "sstpDirectum"
srcDir = "Signaculum/c"
linkLibs = ["user32"]

# ライブラリ本體にゃん。Exemplum（使用例）は含めにゃいにゃ
[[lean_lib]]
name = "Signaculum"
globs = [
  "Signaculum",
  "Signaculum.Protocollum",
  "Signaculum.Sakura.Typi",
  "Signaculum.Sakura.Fundamentum",
  "Signaculum.Sakura.Textus",
  "Signaculum.Sakura.Fenestra",
  "Signaculum.Sakura.Systema",
  "Signaculum.Sakura.Scriptum",
  "Signaculum.Rogatio",
  "Signaculum.Responsum",
  "Signaculum.Nuculum",
  "Signaculum.Exporta",
  "Signaculum.Memoria.StatusPermanens",
  "Signaculum.Memoria.Lemma",
  "Signaculum.Sstp",
  "Signaculum.Syntaxis",
]
